# Firebase Cloud Messaging (Push Notifications)
# Obter em: Firebase Console > Configurações do Projeto > Contas de Serviço > Gerar nova chave privada
# IMPORTANTE: Baixar o JSON e colocar em local seguro fora do webroot
FCM_SERVER_KEY=ya29.exemplo_de_token_fcm_aqui

# WhatsApp API (OPCIONAL - por enquanto usa wa.me direto)
# Evolution API: https://github.com/EvolutionAPI/evolution-api
# WHATSAPP_API_URL=https://sua-instancia.evolution.com/message/sendText
# WHATSAPP_API_KEY=sua-chave-api-aqui

# Banco de Dados
DB_HOST=localhost
DB_NAME=puntotouch
DB_USER=root
DB_PASS=senha

# JWT Secret
JWT_SECRET=sua_chave_secreta_aqui_minimo_32_caracteres

# Environment
ENVIRONMENT=production
